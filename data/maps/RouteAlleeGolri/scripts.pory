mapscripts RouteAlleeGolri_MapScripts {
	MAP_SCRIPT_ON_TRANSITION {
		setvar(VAR_TEMP_1, 1)
	}
}

script RouteAlleeGolri_GoRight {
	lock
	// warp(MAP_ROUTE_ALLEE_GOLRI, 3, 11)
	applymovement(LOCALID_PLAYER, moves(
		face_right
		walk_right
	))
	waitmovement(0)
	release
}

